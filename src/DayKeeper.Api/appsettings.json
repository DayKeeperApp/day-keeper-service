{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://localhost:4317",
          "Protocol": "Grpc",
          "ResourceAttributes": {
            "service.name": "daykeeper-api"
          }
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "OpenTelemetry": {
    "ServiceName": "daykeeper-api",
    "Enabled": true,
    "Tracing": {
      "Enabled": true,
      "ExportIntervalMilliseconds": 5000,
      "SamplingRatio": 1.0
    },
    "Metrics": {
      "Enabled": true,
      "ExportIntervalMilliseconds": 15000
    },
    "Logging": {
      "Enabled": true
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "AttachmentStorage": {
    "BasePath": "/data/attachments",
    "MaxFileSizeBytes": 10485760
  },
  "Firebase": {
    "ProjectId": "day-keeper-8bafb"
  },
  "AllowedHosts": "*"
}
